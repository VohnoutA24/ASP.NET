@{
    ViewData["Title"] = "Přihlášení";
}

<div class="user-page">
    <h1>Přihlášení</h1>
    <p>Přihlaste se do svého účtu.</p>

    @if (TempData["Zprava"] != null)
    {
        <div class="zprava">@TempData["Zprava"]</div>
    }

    @if (ViewBag.Chyba != null)
    {
        <div class="zprava" style="background: rgba(231, 76, 60, 0.15); border-color: rgba(231, 76, 60, 0.3); color: #e74c3c;">@ViewBag.Chyba</div>
    }

    <form method="post" asp-controller="User" asp-action="Login" id="loginForm">
        <div class="form-group">
            <label for="username">Uživatelské jméno <span style="color: #e74c3c;">*</span></label>
            <input type="text" id="username" name="username" placeholder="Vložte jméno" required 
                   oninvalid="this.setCustomValidity('Prosím, vyplňte toto pole.')" 
                   oninput="this.setCustomValidity('')" />
        </div>

        <div class="form-group">
            <label for="heslo">Heslo <span style="color: #e74c3c;">*</span></label>
            <input type="password" id="hesloInput" placeholder="Zadejte heslo" required 
                   oninvalid="this.setCustomValidity('Prosím, vyplňte toto pole.')" 
                   oninput="this.setCustomValidity('')" />
        </div>

        <input type="hidden" id="heslo" name="heslo" />
        <button type="submit">Přihlásit se</button>
    </form>

    <p class="link">Nemáte účet? <a href="/User/Register">Zaregistrujte se</a></p>
</div>

@section Scripts {
    <script>
        document.getElementById('loginForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const raw = document.getElementById('hesloInput').value;
            const encoded = new TextEncoder().encode(raw);
            const hashBuffer = await crypto.subtle.digest('SHA-256', encoded);
            const hashArray = Array.from(new Uint8Array(hashBuffer));
            const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
            document.getElementById('heslo').value = hashHex;
            document.getElementById('hesloInput').value = '';
            this.submit();
        });
    </script>
}
